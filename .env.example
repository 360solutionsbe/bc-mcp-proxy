# Copy to .env and fill in. .env is git-ignored.
# Anything you put here is read by bc_mcp_proxy when no matching CLI flag is supplied.

# ---- Required ----------------------------------------------------------------

# Azure Directory (tenant) ID — Microsoft Entra ID > Overview.
BC_TENANT_ID=

# Azure App Registration client (application) ID. The app needs:
#   - Delegated API permissions: Financials.ReadWrite.All, user_impersonation
#   - Authentication > "Allow public client flows" enabled
#   - A desktop redirect URL: ms-appx-web://Microsoft.AAD.BrokerPlugin/<client-id>
BC_CLIENT_ID=

# Business Central environment name as it appears in the BC admin center.
# Examples: Production, Sandbox, MyDevEnv
BC_ENVIRONMENT=Production

# Exact company name within the environment (case-sensitive).
# Example: "CRONUS USA", "My Company Ltd."
BC_COMPANY=

# ---- Optional ----------------------------------------------------------------

# Optional named MCP configuration in BC. Leave empty if you don't use one.
#BC_CONFIGURATION_NAME=

# Skip the device-code flow by supplying a pre-issued bearer token (testing only).
#BC_CUSTOM_AUTH_HEADER=

# Override the BC MCP base URL.
# v26/v27 (default): https://api.businesscentral.dynamics.com
# v28+              : https://mcp.businesscentral.dynamics.com
# (When set to mcp.businesscentral.dynamics.com the proxy auto-switches to
#  the v28 header-based routing — TenantId and EnvironmentName headers.)
#BC_BASE_URL=

# Override the OAuth scope (default: https://api.businesscentral.dynamics.com/.default).
#BC_TOKEN_SCOPE=

# Logging — DEBUG, INFO, WARNING, ERROR.
#BC_LOG_LEVEL=INFO

# Verbose internal logging.
#BC_DEBUG=0

# HTTP request timeout in seconds (default: 120).
# Raise to 240+ for BC v28 dynamic mode with Discover Additional Objects on
# — first-call catalog enumeration regularly takes 60s+ on cold start.
#BC_HTTP_TIMEOUT_SECONDS=120

# Server-Sent Events read timeout in seconds (default: 300).
#BC_SSE_TIMEOUT_SECONDS=300

# Override the MSAL token cache location/filename.
#BC_DEVICE_CACHE_LOCATION=
#BC_DEVICE_CACHE_NAME=bc_mcp_proxy
